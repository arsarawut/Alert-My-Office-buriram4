MYOFFICE_USERNAME=
MYOFFICE_PASSWORD=
MYOFFICE_NEWS_URL=http://209.15.117.206/myoffice/2569/index.php?name=tkk4&category=132
MYOFFICE_ARCHIVED_NEWS_URL=http://209.15.117.206/myoffice/2569/index.php?name=tkk4&file=rub&category=132&Page=1

# 0 = ดึงทุกหน้าที่พบในแฟ้มรับ, ถ้าต้องการจำกัดให้ใส่จำนวนหน้า เช่น 3
MYOFFICE_ARCHIVED_MAX_PAGES=0

# path สำหรับเก็บ state/lock บนเครื่อง local หรือ cloud
MYOFFICE_STATE_PATH=data/seen_news.json
MYOFFICE_LOCK_PATH=data/check_myoffice_news.lock

# สร้าง bot จาก @BotFather แล้วใส่ token ตรงนี้
TELEGRAM_BOT_TOKEN=

# ใส่ chat id ของผู้รับ หรือ group id เช่น -100xxxxxxxxxx
TELEGRAM_CHAT_ID=

# token ป้องกัน endpoint /run และ /test-telegram บน cloud
RUN_WEBHOOK_TOKEN=change-this-secret

# ถ้ามีไฟล์ CA ขององค์กร/proxy เอง ให้ใส่ path ตรงนี้
TELEGRAM_CA_FILE=

# true = ตรวจ certificate ตามปกติ, false = ข้าม SSL verify เฉพาะ Telegram
# ใช้ false เฉพาะกรณีเครื่องติด self-signed certificate/proxy และยอมรับความเสี่ยงได้
TELEGRAM_SSL_VERIFY=true

REQUEST_TIMEOUT=30
